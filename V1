<script>
  let side = 'BUY';
 
  function setSide(s) {
    side = s;
    document.getElementById('btn-buy').className = 'side-btn' + (s === 'BUY' ? ' active-buy' : '');
    document.getElementById('btn-sell').className = 'side-btn' + (s === 'SELL' ? ' active-sell' : '');
  }
 
  function fmt(n, d = 4) {
    if (n === null || isNaN(n)) return '—';
    return parseFloat(n.toFixed(d)).toLocaleString('en-US', { minimumFractionDigits: d > 4 ? 2 : d });
  }
 
  function calculate() {
    const account  = parseFloat(document.getElementById('account').value);
    const riskPct  = parseFloat(document.getElementById('risk').value);
    const leverage = parseFloat(document.getElementById('leverage').value);
    const entry    = parseFloat(document.getElementById('entry').value);
    const stoploss = parseFloat(document.getElementById('stoploss').value);
    const pair     = document.getElementById('pair').value;
 
    // Validation
    if ([account, riskPct, leverage, entry, stoploss].some(isNaN) || entry <= 0 || stoploss <= 0) {
      alert('Please fill in all fields with valid numbers.');
      return;
    }
 
    // Side validation
    if (side === 'BUY' && stoploss >= entry) {
      alert('For a LONG position, Stop Loss must be BELOW the Entry price.');
      return;
    }
    if (side === 'SELL' && stoploss <= entry) {
      alert('For a SHORT position, Stop Loss must be ABOVE the Entry price.');
      return;
    }
 
    // Core calculations
    const riskUSDT   = account * (riskPct / 100);
    const slDist     = Math.abs(entry - stoploss);
    const slPct      = (slDist / entry) * 100;
 
    // Quantity = Risk Amount / SL Distance (in coins)
    const qty        = riskUSDT / slDist;
    const notional   = qty * entry;
    const margin     = notional / leverage;
 
    // Estimated liquidation (simplified: margin / qty offset from entry)
    // Liq ≈ entry - (margin / qty) * leverage  [for long]
    const liqOffset  = entry / leverage;
    const liqPrice   = side === 'BUY'
      ? entry - liqOffset * 0.9
      : entry + liqOffset * 0.9;
 
    // Base asset name
    const base = pair === 'OTHER' ? 'COIN' : pair.replace('USDT','');
 
    // Display
    document.getElementById('res-qty').textContent       = fmt(qty, 4);
    document.getElementById('res-base').textContent      = base;
    document.getElementById('res-usdt-val').textContent  = fmt(notional, 2);
    document.getElementById('res-risk-usdt').textContent = fmt(riskUSDT, 2) + ' USDT';
    document.getElementById('res-risk-pct').textContent  = fmt(riskPct, 1) + '%';
    document.getElementById('res-margin').textContent    = fmt(margin, 4) + ' USDT';
    document.getElementById('res-sl-dist').textContent   = fmt(slDist, 6);
    document.getElementById('res-sl-pct').textContent    = fmt(slPct, 2) + '%';
    document.getElementById('res-liq').textContent       = '≈ ' + fmt(liqPrice, 4);
 
    // Risk bar (cap at 20%)
    const barW = Math.min((riskPct / 20) * 100, 100);
    document.getElementById('risk-bar').style.width = barW + '%';
    document.getElementById('bar-label').textContent = fmt(riskPct, 1) + '%';
 
    // Summary
    const isLong = side === 'BUY';
    const summaryEl = document.getElementById('summary-box');
    summaryEl.className = 'summary-box ' + (isLong ? 'buy-box' : '');
    summaryEl.innerHTML = `
      <b style="color:${isLong ? 'var(--green)' : 'var(--red)'}; letter-spacing:2px;">${isLong ? '▲ LONG' : '▼ SHORT'} · ${pair}</b><br><br>
      Entry: <span>${fmt(entry, 6)} USDT</span> &nbsp;|&nbsp; SL: <span>${fmt(stoploss, 6)} USDT</span><br>
      Leverage: <span>${leverage}×</span> &nbsp;|&nbsp; Balance: <span>${fmt(account, 2)} USDT</span><br><br>
      Order Size: <span class="accent">${fmt(qty, 4)} ${base}</span> (${fmt(notional, 2)} USDT)<br>
      Margin Used: <span>${fmt(margin, 4)} USDT</span> &nbsp;·&nbsp; Risk: <span style="color:var(--red)">${fmt(riskUSDT, 2)} USDT (${fmt(riskPct,1)}%)</span>
    `;
 
    document.getElementById('results').className = 'results show';
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
 
  // Allow Enter key
  document.addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
</script>
